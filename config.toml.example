# =============================================================================
# config.toml — cấu hình trung tâm cho AI Director Video Commentary (bản Colab)
# Không còn dùng .env / os.getenv. Mọi module đọc cấu hình từ file này.
# =============================================================================

[api]
# API key và endpoint cho LLM viết kịch bản (thay thế Claude built-in).
# Model: Gemma 4 31B chạy trên Cerebras Cloud (OpenAI-compatible endpoint).
cerebras_api_key = "PASTE_YOUR_CEREBRAS_API_KEY_HERE"
cerebras_base_url = "https://api.cerebras.ai/v1"
cerebras_model = "zai-glm-4.7"
cerebras_max_tokens = 8000
cerebras_temperature = 0.8

# Hugging Face token — chỉ cần nếu Qwen3-VL-4B-Instruct hoặc model cần auth.
hf_token = ""

# API key cho vision backend "mistral" (độc lập với Cerebras ở trên — chỉ
# dùng riêng cho stage đọc ảnh, không đụng tới engine viết kịch bản).
mistral_api_key = "PASTE_YOUR_MISTRAL_API_KEY_HERE"
mistral_base_url = "https://api.mistral.ai/v1"

[tts]
# edge-tts: không cần API key, chỉ cần chọn giọng.
engine = "edge-tts"
# Giọng mặc định. Ví dụ khác: "en-US-JennyNeural", "vi-VN-NamMinhNeural"
voice = "vi-VN-HoangMinhNeural"
rate = "+0%"
volume = "+0%"
pitch = "+0Hz"

[processing]
# ---- ASR (faster-whisper) ----
asr_model_size = "small"          # tiny/base/small/medium/large-v3
asr_device = "auto"               # auto | cuda | cpu
asr_compute_type = "auto"         # auto | float16 | int8
asr_language = "vi"               # mã ngôn ngữ ASR, để trống "" để auto-detect

# ---- Vision ----
# "local" (mặc định, cần GPU) | "cerebras" (Gemma 4 31B qua API — free tier chỉ 5 RPM/
# 30K TPM/1M TPD, tối đa 2 ảnh/request; không hợp cho video nhiều scene, chỉ dùng cho
# video ngắn hoặc khi không có GPU. Chất lượng đọc ảnh của Gemma 4 cũng yếu hơn model
# vision chuyên dụng.)
vision_backend = "mistral"
cerebras_vision_model = "gemma-4-31b"
cerebras_vision_max_images = 2
cerebras_vision_rpm = 5

# ---- Vision backend "mistral" ----
mistral_vision_model = "mistral-large-latest"   # model multimodal lớn nhất của Mistral hiện tại
mistral_vision_max_images = 8                  # số ảnh tối đa gửi mỗi request (frames_per_scene thường <= số này)
mistral_vision_rpm = 15                        # throttle nhẹ để tránh 429, có retry tự động nếu vượt

vision_model_name = "Qwen/Qwen3-VL-4B-Instruct"
vision_device = "auto"            # auto | cuda | cpu
vision_dtype = "float16"          # float16 | bfloat16 | float32
vision_max_new_tokens = 512
vision_attn_implementation = "sdpa"  # sdpa | flash_attention_2 (tự fallback nếu không hỗ trợ)
vision_batch_size = 4              # tăng nếu còn dư VRAM (không đổi chất lượng, chỉ tăng thông lượng GPU)
# Số khung hình đại diện lấy ra cho mỗi scene khi phân tích thị giác.
vision_frames_per_scene = 3

# ---- Scene detection ----
scene_threshold = 27.0            # ngưỡng PySceneDetect (ContentDetector)
min_scene_len_sec = 1.0

# ---- Narration / storyboard ----
narration_pov = "third_person"    # third_person | first_person
content_type = "movie"            # movie | tv_drama | anime | short_drama | foreign_language_commentary
genre = "drama"
target_duration_sec = 180
chars_per_sec = 4.0                # tốc độ đọc ước tính CHO VĂN BẢN CHỮ HÁN (số ký tự/giây)
words_per_sec = 2.5                 # tốc độ đọc ước tính CHO TIẾNG VIỆT/TIẾNG ANH (số từ/giây)
buffer_after_speech = 0.1
min_clip_duration = 1.0
max_speed_ratio = 4.0              # source_duration / output_duration tối đa cho phép

# ---- Checkpoint frequency ----
# micro_checkpoint_interval: lưu checkpoint mỗi N item (scene/batch)
# Càng thấp = càng gần real-time. Mặc định: 1 = mỗi item.
micro_checkpoint_interval = 1
# auto_sync_cloud: tự động sync lên Filebase sau mỗi checkpoint
auto_sync_cloud = true

[paths]
input_video = "./input/source.mp4"
output_dir = "./output"
checkpoint_dir = "./checkpoints"
model_cache_dir = "./model_cache"
# projects_dir: nơi lưu toàn bộ project
projects_dir = "./projects"

[filebase]
# Thông tin xác thực lưu trữ Filebase (tương thích S3)
# Access key để xác thực
access_key = "PASTE_YOUR_FILEBASE_ACCESS_KEY_HERE"
# Secret key để xác thực
secret_key = "PASTE_YOUR_FILEBASE_SECRET_KEY_HERE"
# Tên bucket — PHẢI DUY NHẤT TOÀN CỤC trên Filebase (giống S3), hãy đổi
# thành tên riêng của bạn, đừng dùng nguyên giá trị mặc định.
bucket_name = "ai-director-video"
# Filebase S3 endpoint
endpoint_url = "https://s3.filebase.com"
# Bật/tắt tính năng sync cloud
enabled = true

[project]
# Cấu hình mặc định cho quản lý project
auto_project_scan = true
show_project_menu_on_start = true
# Khoảng thời gian tự lưu, tính bằng giây (0 = sau mỗi stage)
auto_save_interval = 0
# Số lần thử lại tối đa khi sync cloud thất bại
cloud_sync_retries = 3
